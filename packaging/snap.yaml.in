name: unix-utility-suite
version: '@VERSION@'
summary: GUI launcher for Linux system utilities
description: |
  Unix Utility Suite is a Zenity-based desktop launcher for common Linux
  utility tasks, including system information, media launching, file search,
  package updates, PDF opening, arithmetic, process termination, scheduling
  simulation, service management, and network throughput monitoring.
base: core24
grade: stable
confinement: classic
apps:
  unix-toolkit:
    command: usr/bin/unix-toolkit
    desktop: usr/share/applications/unix-toolkit.desktop
